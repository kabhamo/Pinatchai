# Sanity — copy to .env.local and fill in. Get values from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: only needed for authenticated writes / drafts
SANITY_API_TOKEN=

# Public site URL (used for canonical + sitemap)
NEXT_PUBLIC_SITE_URL=https://pinat-hai-burgata.netlify.app
